<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mochila do Carlin - Minha Matéria</title>

<style>
body {
    font-family: Arial, sans-serif;
    background: linear-gradient(135deg, #667eea, #764ba2);
    margin: 0;
    text-align: center;
    color: white;
}

h1 {
    margin-top: 20px;
}

.container {
    background: white;
    color: black;
    max-width: 500px;
    margin: 30px auto;
    padding: 20px;
    border-radius: 15px;
    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
}

input {
    padding: 10px;
    width: 65%;
    border-radius: 5px;
    border: 1px solid #ccc;
}

button {
    padding: 10px;
    border: none;
    border-radius: 5px;
    background: #667eea;
    color: white;
    cursor: pointer;
    margin-left: 5px;
}

button:hover {
    background: #5a67d8;
}

ul {
    list-style: none;
    padding: 0;
    margin-top: 20px;
}

li {
    background: #f1f1f1;
    margin: 8px 0;
    padding: 10px;
    border-radius: 5px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.remover {
    background: red;
    color: white;
}

.footer {
    margin-top: 20px;
    font-size: 14px;
}
</style>
</head>

<body>

<h1>🎒 Mochila do Carlin</h1>
<p>Minha Matéria 📚</p>

<div class="container">
    <input type="text" id="itemInput" placeholder="Digite o material da matéria...">
    <button onclick="adicionarItem()">Adicionar</button>

    <ul id="listaItens"></ul>
</div>

<div class="footer">
    Trabalho Escolar | Desenvolvido por Carlin ✏️
</div>

<script>
const lista = document.getElementById("listaItens");
const input = document.getElementById("itemInput");

// Carregar itens salvos
window.onload = function() {
    const itensSalvos = JSON.parse(localStorage.getItem("mochilaMateria")) || [];
    itensSalvos.forEach(item => criarItem(item));
};

function adicionarItem() {
    if (input.value.trim() === "") return;

    criarItem(input.value);
    salvarItem(input.value);
    input.value = "";
}

function criarItem(texto) {
    const li = document.createElement("li");
    li.innerHTML = "📘 " + texto;

    const botaoRemover = document.createElement("button");
    botaoRemover.textContent = "X";
    botaoRemover.classList.add("remover");

    botaoRemover.onclick = function() {
        li.remove();
        removerItem(texto);
    };

    li.appendChild(botaoRemover);
    lista.appendChild(li);
}

function salvarItem(item) {
    const itens = JSON.parse(localStorage.getItem("mochilaMateria")) || [];
    itens.push(item);
    localStorage.setItem("mochilaMateria", JSON.stringify(itens));
}

function removerItem(item) {
    let itens = JSON.parse(localStorage.getItem("mochilaMateria")) || [];
    itens = itens.filter(i => i !== item);
    localStorage.setItem("mochilaMateria", JSON.stringify(itens));
}
</script>

</body>
</html>
    
